---
const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title wayweft-title sl-flex">
  <span class="wayweft-mark" aria-hidden="true">
    <svg viewBox="0 0 48 48" role="img" focusable="false">
      <path d="M6 12c4 0 6 2 8 8l4 12c1.2 3.6 2.7 4 6 4 2.8 0 4.2-.9 5.4-4.7L36 12c1.5 5 3 10 4.4 15 1 3.4 2 5.2 4.6 5.2" />
      <path d="M6 36c4 0 5.5-1.7 6.7-5.3L18 12c1.4 4.5 2.8 9.1 4.3 13.7 1.3 4.1 2.7 6.3 5.7 6.3 2.7 0 4.1-1.8 5.2-5.8L38 12c1.3 3.7 2.3 6.1 4 7.8" />
    </svg>
  </span>
  <span class="wayweft-wordmark" translate="no">{siteTitle}</span>
</a>

<style>
  .wayweft-title {
    align-items: center;
    gap: 0.65rem;
    color: var(--sl-color-text-accent);
    text-decoration: none;
    min-width: 0;
    transition: opacity 0.2s;
  }

  .wayweft-title:hover {
    opacity: 0.8;
  }

  .wayweft-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.15rem;
    height: 2.15rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 25%, transparent);
    border-radius: 0.55rem;
    background:
      linear-gradient(150deg, rgba(255, 255, 255, 0.55), rgba(243, 235, 220, 0.75));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.4),
      0 1px 2px rgba(26, 31, 53, 0.04);
    flex: none;
  }

  .wayweft-mark svg {
    width: 1.35rem;
    height: 1.35rem;
    stroke: var(--sl-color-text);
    stroke-width: 2.4;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .wayweft-wordmark {
    font-family: var(--wayweft-font-heading);
    font-size: 1.15rem;
    font-weight: 560;
    letter-spacing: -0.04em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global([data-theme='dark']) .wayweft-mark {
    background:
      linear-gradient(150deg, rgba(30, 35, 56, 0.9), rgba(22, 27, 44, 0.85));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 1px 2px rgba(0, 0, 0, 0.15);
  }
</style>
